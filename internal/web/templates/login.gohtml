<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>StockIt Login</title>
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="stylesheet" href="/assets/vendor/tailwind.min.css">
  <link rel="stylesheet" href="/assets/app/app.css">
</head>
<body class="stockit-login-shell min-h-screen text-slate-900">
  <main class="mx-auto flex min-h-screen max-w-md items-center px-4 py-8">
    <section class="stockit-login-card w-full">
      <header class="mb-6">
        <p class="stockit-brand-mark">StockIt</p>
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Warehouse management app</h1>
        <p class="mt-2 text-sm text-slate-600">A modern control surface for inventory, BOMs, locations, and supplier data.</p>
      </header>
      {{ if .Error }}
      <div class="stockit-inline-message stockit-inline-message-error mb-4">{{ .Error }}</div>
      {{ end }}
      <form method="post" action="/login" class="space-y-4">
        <label class="stockit-field-label">
          Login
          <input class="stockit-input mt-2 block w-full" type="text" name="login_name" autocomplete="username" required autofocus>
        </label>
        <label class="stockit-field-label">
          Password
          <input class="stockit-input mt-2 block w-full" type="password" name="password" autocomplete="current-password" required>
        </label>
        <button class="stockit-button stockit-button-primary inline-flex w-full" type="submit">Sign In</button>
      </form>
      <div class="mt-6 border-t border-slate-200/80 pt-4 text-xs text-slate-500">
        Default credentials: admin/admin, user/user, guest/guest.
      </div>
    </section>
  </main>
</body>
</html>
