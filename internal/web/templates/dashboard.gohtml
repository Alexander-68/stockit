<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>StockIt</title>
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="stylesheet" href="/assets/vendor/tailwind.min.css">
  <link rel="stylesheet" href="/assets/app/app.css">
  <script src="/assets/vendor/htmx.min.js" defer></script>
  <script src="/assets/app/app.js" defer></script>
</head>
<body class="stockit-app-shell h-screen overflow-hidden text-slate-900">
  <main class="stockit-app-main flex h-screen flex-col">
    <header class="stockit-topbar">
      <div class="stockit-brand min-w-0">
        <p class="stockit-brand-mark">StockIt</p>
        <h1 class="stockit-brand-title">Warehouse Control Surface</h1>
        <p class="stockit-brand-meta truncate">{{ .User.LoginName }} · {{ .User.Role }}</p>
      </div>
      <nav class="stockit-topnav flex min-w-0 flex-1 gap-2 overflow-x-auto pb-1">
        {{ range .Tables }}
        <button
          type="button"
          class="stockit-nav shrink-0"
          data-table="{{ .Name }}"
          onclick="StockIt.loadTable('{{ .Name }}')"
        >{{ .Label }}</button>
        {{ end }}
      </nav>
      <form hx-post="/logout" hx-confirm="Log out?" class="shrink-0">
        <button class="stockit-button stockit-button-ghost" type="submit">Logout</button>
      </form>
    </header>

    <section class="stockit-workspace relative flex min-h-0 flex-1 flex-col">
      <div id="stockit-flash" class="stockit-flash pointer-events-none absolute left-4 right-4 top-4 z-20 hidden"></div>
      <div id="table-panel" class="stockit-panel-host flex min-h-0 flex-1 flex-col"></div>
    </section>
  </main>

  <div id="stockit-modal" class="stockit-modal-backdrop hidden fixed inset-0 z-40 items-center justify-center px-4 py-4" onclick="StockIt.maybeCloseModal(event)">
    <div class="stockit-modal-shell w-full">
      <div id="modal-body" class="stockit-modal-body"></div>
    </div>
  </div>

  <script>
    window.addEventListener("DOMContentLoaded", function () {
      StockIt.boot("{{ .DefaultTable }}");
    });
  </script>
</body>
</html>
